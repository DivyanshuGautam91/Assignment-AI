# Sift AI Spend Audit - Environmental Configurations Example
# Copy this file to a new '.env' file in the root folder and configure your keys.

# -----------------------------------------------------------------------------
# 1. SUPABASE DATABASE CONFIGURATION (MANDATORY FOR CLOUD PERSISTENCE)
# -----------------------------------------------------------------------------
# Retrieve these from your Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# 2. AI COMPLETION ENGINE API CONFIGURATION (OPTIONAL - FOR REAL AI SUMMARY)
# -----------------------------------------------------------------------------
# Fill exactly ONE of these to enable real AI-generated summaries on Results.
# If both are empty, the engine gracefully falls back to deterministic summaries.
VITE_OPENAI_API_KEY=sk-proj-...
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...
